APP_NAME=AI Tender Assistant
APP_ENV=development
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=tender
AGENT_USE_REAL_LLM=false
OPENCLAW_COMMAND=openclaw.ps1
OPENCLAW_TIMEOUT_SECONDS=120
OPENCLAW_THINKING=minimal
OPENCLAW_AGENT_EXTRACT=tender-extract
OPENCLAW_AGENT_JUDGE=tender-judge
OPENCLAW_AGENT_GENERATE=tender-generate
OPENCLAW_MODEL_DEFAULT=openai-codex/gpt-5.4
OPENCLAW_STATE_DIR=
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
